{
  "name": "todo-app",
  "private": true,
  "scripts": {
    "dev:api": "turbo run dev --filter=@todo-app/api",
    "dev:mobile": "turbo run dev --filter=@todo-app/mobile",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @todo-app/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @todo-app/api exec prisma db seed",
    "db:studio": "pnpm --filter @todo-app/api exec prisma studio"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "unrs-resolver"
    ]
  }
}

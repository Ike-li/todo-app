{
  "name": "todo-app",
  "private": true,
  "scripts": {
    "dev:api": "turbo run dev --filter=@todo-app/api",
    "dev:mobile": "turbo run dev --filter=@todo-app/mobile",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:mobile-e2e": "maestro test .maestro/",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @todo-app/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @todo-app/api exec prisma db seed",
    "db:studio": "pnpm --filter @todo-app/api exec prisma studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "unrs-resolver"
    ],
    "overrides": {
      "postcss": ">=8.5.10",
      "@tootallnate/once": ">=3.0.1"
    }
  },
  "lint-staged": {
    "apps/api/**/*.{ts,tsx}": [
      "pnpm --filter api lint"
    ],
    "apps/mobile/**/*.{ts,tsx}": [
      "pnpm --filter @todo-app/mobile lint"
    ],
    "packages/shared/**/*.ts": [
      "pnpm --filter @todo-app/shared lint"
    ]
  }
}
